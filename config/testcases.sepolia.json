{
  "env": "sepolia",
  "timing": {
    "period_seconds": 60,
    "sleep_pad_seconds": 10
  },
  "tests": [
    {
      "id": "T00",
      "name_ru": "Деплой и создание пула (smoke)",
      "description_ru": "Шаги Step1/Step2 + применение конфига + проверка FLOOR",
      "mandatory": true,
      "steps": [
        { "op": "deploy_hook" },
        { "op": "configure_hook_from_conf" },
        { "op": "create_pool" },
        { "op": "assert_fee", "tier": "FLOOR" },
        { "op": "read_state" }
      ]
    },
    {
      "id": "T10",
      "name_ru": "EXTREME confirm = 2 works",
      "description_ru": "На N-1 перехода в EXTREME нет, на N=2 есть",
      "mandatory": true,
      "steps": [
        {
          "op": "assert_confirm_logic",
          "kind": "up_extreme",
          "start_tier": "CASH",
          "target_tier": "EXTREME",
          "confirm_periods": 2,
          "direction": "stable_to_volatile",
          "amount": 25000000,
          "require_hold_zero": false
        },
        { "op": "read_state" }
      ]
    },
    {
      "id": "T11",
      "name_ru": "DOWN_EXTREME_CONFIRM = 2 works",
      "description_ru": "На N-1 из EXTREME не уходим, на N=2 уходим в CASH",
      "mandatory": true,
      "steps": [
        {
          "op": "assert_confirm_logic",
          "kind": "down_extreme",
          "start_tier": "EXTREME",
          "target_tier": "CASH",
          "confirm_periods": 2,
          "direction": "stable_to_volatile",
          "amount": 2000000,
          "require_hold_zero": true
        },
        { "op": "read_state" }
      ]
    },
    {
      "id": "T12",
      "name_ru": "DOWN_CASH_CONFIRM = 3 works",
      "description_ru": "На N-1 и N-2 остаёмся в CASH, на N=3 уходим в FLOOR",
      "mandatory": true,
      "steps": [
        {
          "op": "assert_confirm_logic",
          "kind": "down_cash",
          "start_tier": "CASH",
          "target_tier": "FLOOR",
          "confirm_periods": 3,
          "direction": "stable_to_volatile",
          "amount": 2000000,
          "require_hold_zero": true
        },
        { "op": "read_state" }
      ]
    },
    {
      "id": "T13",
      "name_ru": "EMERGENCY_CONFIRM = 3 works",
      "description_ru": "Три подряд low-volume периода: N-1 и N-2 без emergency, на N=3 emergency -> FLOOR",
      "mandatory": true,
      "steps": [
        {
          "op": "assert_confirm_logic",
          "kind": "emergency_floor",
          "start_tier": "CASH",
          "target_tier": "FLOOR",
          "confirm_periods": 3,
          "direction": "stable_to_volatile",
          "amount": 500000,
          "require_hold_zero": false
        },
        { "op": "read_state" }
      ]
    },
    {
      "id": "T20",
      "name_ru": "Creator fee accrual + claim",
      "description_ru": "Accrual растёт, claim обнуляет accrued и увеличивает баланс recipient; percent above limit даёт revert",
      "mandatory": true,
      "steps": [
        { "op": "set_creator_fee_address_to_creator" },
        { "op": "read_state", "capture_creator_fees": true },
        { "op": "sleep_periods", "n": 1 },
        { "op": "swap_exact_in", "direction": "stable_to_volatile", "amount": 12000000 },
        { "op": "sleep_periods", "n": 1 },
        { "op": "swap_exact_in", "direction": "stable_to_volatile", "amount": 14000000 },
        { "op": "sleep_periods", "n": 1 },
        { "op": "swap_exact_in", "direction": "stable_to_volatile", "amount": 16000000 },
        { "op": "assert_creator_fee_accrued", "min_delta_any": 1 },
        { "op": "claim_creator_fee_and_assert" },
        {
          "op": "expect_revert",
          "call": {
            "op": "set_creator_fee_percent",
            "value_percent": 11
          },
          "expected": "CreatorFeePercentLimitExceeded"
        },
        { "op": "read_state" }
      ]
    }
  ]
}

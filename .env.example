# Environment template for multi-network deploys
# Copy to ".env" and fill only networks you use.
# This file is safe to commit; never commit real ".env" values.

# Optional global fallbacks used by config/hook.<chain>.conf.
# Chain-specific values below have priority over these defaults.
DEFAULT_PRIVATE_KEY=0xYOUR_DEFAULT_PRIVATE_KEY
DEFAULT_OWNER=0xYOUR_DEFAULT_OWNER

# Local (chain selector: local)
LOCAL_PRIVATE_KEY=0xYOUR_LOCAL_PRIVATE_KEY
LOCAL_OWNER=0xYOUR_LOCAL_OWNER

# Sepolia (chain selector: sepolia)
SEPOLIA_PRIVATE_KEY=0xYOUR_SEPOLIA_PRIVATE_KEY
SEPOLIA_OWNER=0xYOUR_SEPOLIA_OWNER

# Arbitrum (chain selector: arbitrum)
ARBITRUM_PRIVATE_KEY=0xYOUR_ARBITRUM_PRIVATE_KEY
ARBITRUM_OWNER=0xYOUR_ARBITRUM_OWNER

# Base (chain selector: base)
BASE_PRIVATE_KEY=0xYOUR_BASE_PRIVATE_KEY
BASE_OWNER=0xYOUR_BASE_OWNER

# Ethereum (chain selector: ethereum)
ETHEREUM_PRIVATE_KEY=0xYOUR_ETHEREUM_PRIVATE_KEY
ETHEREUM_OWNER=0xYOUR_ETHEREUM_OWNER

# Optimism (chain selector: optimism)
OPTIMISM_PRIVATE_KEY=0xYOUR_OPTIMISM_PRIVATE_KEY
OPTIMISM_OWNER=0xYOUR_OPTIMISM_OWNER

# Polygon (chain selector: polygon)
POLYGON_PRIVATE_KEY=0xYOUR_POLYGON_PRIVATE_KEY
POLYGON_OWNER=0xYOUR_POLYGON_OWNER

# Optimism live operational defaults
OPS_RUNTIME=live
CHAIN_ID_EXPECTED=10
RPC_URL=https://optimism-rpc.publicnode.com

PRIVATE_KEY=${OPTIMISM_PRIVATE_KEY:-${DEFAULT_PRIVATE_KEY:-}}
DEPLOYER=
OWNER=${OPTIMISM_OWNER:-${DEFAULT_OWNER:-}}

POOL_MANAGER=0x9a13F98Cb987694C9F086b1F5eB990EeA8264Ec3
HOOK_ADDRESS=
POOL_ADDRESS=
VOLATILE=0x0000000000000000000000000000000000000000
STABLE=0x0b2C639c533813f4Aa9D7837CAf62653d097Ff85

STABLE_DECIMALS=6
TICK_SPACING=10

# Bootstrap price/range must be set explicitly before live pool/liquidity flows.
INIT_PRICE_USD=
LIQ_RANGE_MIN_USD=
LIQ_RANGE_MAX_USD=
MAX_SWAP_FRACTION_BPS=800
INIT_SQRT_PRICE_X96=

FLOOR_FEE_PIPS=400
CASH_FEE_PIPS=2500
EXTREME_FEE_PIPS=9000

PERIOD_SECONDS=300
EMA_PERIODS=36
# Literal percent, not bps. Example: 5 = 5%, 1.25 = 1.25%.
DEADBAND_PERCENT=10
LULL_RESET_SECONDS=1800

HOOK_FEE_PERCENT=1
MIN_COUNTED_SWAP_USD6=4000000
# Dollar thresholds below are literal USD amounts per close, not USD6.
# EMA thresholds are literal percent of closeVol / EMA. Example: 180 = 180% of EMA.
MIN_VOLUME_TO_ENTER_CASH_USD=1000
CASH_ENTER_EMA_PERCENT=180
CASH_HOLD_PERIODS=4
MIN_VOLUME_TO_ENTER_EXTREME_USD=4000
EXTREME_ENTER_EMA_PERCENT=400
ENTER_EXTREME_CONFIRM_PERIODS=2
EXTREME_HOLD_PERIODS=4
EXTREME_EXIT_EMA_PERCENT=130
EXIT_EXTREME_CONFIRM_PERIODS=2
CASH_EXIT_EMA_PERCENT=130
EXIT_CASH_CONFIRM_PERIODS=3
EMERGENCY_FLOOR_TRIGGER_USD=600
EMERGENCY_CONFIRM_PERIODS=3

# Live budgets default to explicit operator provisioning.
BUDGET_MIN_ETH_WEI=0
BUDGET_MIN_STABLE_RAW=0
BUDGET_MIN_VOLATILE_RAW=0
BUDGET_LIQ_STABLE_RAW=0
BUDGET_LIQ_VOLATILE_RAW=0
BUDGET_SWAP_STABLE_RAW=0
BUDGET_SWAP_VOLATILE_RAW=0
BUDGET_SAFETY_BUFFER_ETH_WEI=0

SWAP_DRIVER=
LIQUIDITY_DRIVER=

SMOKE_SWAP_STABLE_RAW=0
FULL_SWAP_STABLE_RAW=0
FULL_SWAP_ITERATIONS=4
RERUN_SWAP_STABLE_RAW=0

OPS_BROADCAST=0

# Sepolia operational defaults
OPS_RUNTIME=live
CHAIN_ID_EXPECTED=11155111
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

PRIVATE_KEY=${SEPOLIA_PRIVATE_KEY:-${DEFAULT_PRIVATE_KEY:-}}
DEPLOYER=
OWNER=${SEPOLIA_OWNER:-${DEFAULT_OWNER:-}}

# Network bindings (explicit config; override per environment)
POOL_MANAGER=0xE03A1074c86CFeDd5C142C4F04F1a1536e203543
HOOK_ADDRESS=
POOL_ADDRESS=
VOLATILE=0x0000000000000000000000000000000000000000
STABLE=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

STABLE_DECIMALS=6
TICK_SPACING=10

# Price / range survivability
INIT_PRICE_USD=2500
LIQ_RANGE_MIN_USD=1800
LIQ_RANGE_MAX_USD=3200
MAX_SWAP_FRACTION_BPS=800

# If pool initialization is required, override this with chain-correct value.
INIT_SQRT_PRICE_X96=3961408125713216879677197

# Explicit regime fees in pips (1e-6)
FLOOR_FEE_PIPS=400
CASH_FEE_PIPS=2500
EXTREME_FEE_PIPS=9000

# Timing
PERIOD_SECONDS=60
EMA_PERIODS=12
# Literal percent, not bps. Example: 5 = 5%, 1.25 = 1.25%.
DEADBAND_PERCENT=10
LULL_RESET_SECONDS=300

# Owner / controller params
HOOK_FEE_PERCENT=10
MIN_COUNTED_SWAP_USD6=4000000
# Dollar thresholds below are literal USD amounts per close, not USD6.
# EMA thresholds are literal percent of closeVol / EMA. Example: 180 = 180% of EMA.
MIN_VOLUME_TO_ENTER_CASH_USD=10
CASH_ENTER_EMA_PERCENT=110
CASH_HOLD_PERIODS=4
MIN_VOLUME_TO_ENTER_EXTREME_USD=20
EXTREME_ENTER_EMA_PERCENT=120
ENTER_EXTREME_CONFIRM_PERIODS=2
EXTREME_HOLD_PERIODS=4
EXTREME_EXIT_EMA_PERCENT=130
EXIT_EXTREME_CONFIRM_PERIODS=2
CASH_EXIT_EMA_PERCENT=130
EXIT_CASH_CONFIRM_PERIODS=3
EMERGENCY_FLOOR_TRIGGER_USD=1
EMERGENCY_CONFIRM_PERIODS=3

# Budget guardrails
BUDGET_MIN_ETH_WEI=100000000000000000
BUDGET_MIN_STABLE_RAW=10000000
BUDGET_MIN_VOLATILE_RAW=0
BUDGET_LIQ_STABLE_RAW=20000000

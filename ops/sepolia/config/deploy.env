# Deployment snapshot and bootstrap inputs for this profile.
# Keep DEPLOY_* values aligned with the constructor args used for deployment.
# DEPLOY_* values must be literal and must not depend on shell expansion.

# Pool binding
# PoolManager address baked into the constructor snapshot.
DEPLOY_POOL_MANAGER=0xE03A1074c86CFeDd5C142C4F04F1a1536e203543
# Volatile token address baked into the constructor snapshot.
DEPLOY_VOLATILE=0x0000000000000000000000000000000000000000
# Stable token address baked into the constructor snapshot.
DEPLOY_STABLE=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
# Stable-token decimals baked into the constructor snapshot.
DEPLOY_STABLE_DECIMALS=6
# Pool tick spacing baked into the constructor snapshot.
DEPLOY_TICK_SPACING=10

# Ownership
# Owner address baked into the constructor snapshot.
DEPLOY_OWNER=

# LP fee regimes
# FLOOR LP fee baked into the constructor snapshot, as a percent.
DEPLOY_FLOOR_FEE_PERCENT=0.04
# CASH LP fee baked into the constructor snapshot, as a percent.
DEPLOY_CASH_FEE_PERCENT=0.25
# EXTREME LP fee baked into the constructor snapshot, as a percent.
DEPLOY_EXTREME_FEE_PERCENT=0.9

# Timing
# Close period length baked into the constructor snapshot, in seconds.
DEPLOY_PERIOD_SECONDS=60
# EMA denominator baked into the constructor snapshot.
DEPLOY_EMA_PERIODS=12
# Idle time baked into the constructor snapshot, in seconds.
DEPLOY_LULL_RESET_SECONDS=300
# Additional trader fee baked into the constructor snapshot, as a percent of the active LP fee.
DEPLOY_HOOK_FEE_PERCENT=10

# Controller thresholds
# Minimum close volume baked into the constructor snapshot for FLOOR -> CASH, in USD.
DEPLOY_MIN_VOLUME_TO_ENTER_CASH_USD=10
# Close volume trigger baked into the constructor snapshot for FLOOR -> CASH, as x EMA.
DEPLOY_CASH_ENTER_TRIGGER_EMA_X=1.20
# CASH hold length baked into the constructor snapshot.
DEPLOY_CASH_HOLD_PERIODS=4
# Minimum close volume baked into the constructor snapshot for CASH -> EXTREME, in USD.
DEPLOY_MIN_VOLUME_TO_ENTER_EXTREME_USD=20
# Close volume trigger baked into the constructor snapshot for CASH -> EXTREME, as x EMA.
DEPLOY_EXTREME_ENTER_TRIGGER_EMA_X=1.30
# Required confirming closes baked into the constructor snapshot for CASH -> EXTREME.
DEPLOY_ENTER_EXTREME_CONFIRM_PERIODS=2
# EXTREME hold length baked into the constructor snapshot.
DEPLOY_EXTREME_HOLD_PERIODS=4
# Close volume trigger baked into the constructor snapshot for EXTREME -> CASH, as x EMA.
DEPLOY_EXTREME_EXIT_TRIGGER_EMA_X=1.20
# Required confirming closes baked into the constructor snapshot for EXTREME -> CASH.
DEPLOY_EXIT_EXTREME_CONFIRM_PERIODS=2
# Close volume trigger baked into the constructor snapshot for CASH -> FLOOR, as x EMA.
DEPLOY_CASH_EXIT_TRIGGER_EMA_X=1.20
# Required confirming closes baked into the constructor snapshot for CASH -> FLOOR.
DEPLOY_EXIT_CASH_CONFIRM_PERIODS=3
# Emergency floor trigger baked into the constructor snapshot, in USD.
DEPLOY_EMERGENCY_FLOOR_TRIGGER_USD=1
# Required confirming closes baked into the constructor snapshot for the emergency floor reset.
DEPLOY_EMERGENCY_CONFIRM_PERIODS=3

# Pool bootstrap
# Initial pool price in USD used to initialize the pool onchain.
INIT_PRICE_USD=2500

# Runtime mode for this profile.
OPS_RUNTIME=local
# Chain ID expected from the connected RPC.
CHAIN_ID_EXPECTED=31337
# RPC endpoint used by local scripts and tests.
RPC_URL=http://127.0.0.1:8545

# Private key used to sign local transactions.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Deployer address used when signing happens outside this config.
DEPLOYER=
# Owner address for admin actions and HookFee withdrawals.
OWNER=${LOCAL_OWNER:-${DEFAULT_OWNER:-}}

# Existing hook address used by reuse and validation flows.
HOOK_ADDRESS=
# Existing pool address used by reuse and validation flows.
POOL_ADDRESS=

# Minimum ETH balance required before running ops.
BUDGET_MIN_ETH_WEI=50000000000000000
# Minimum stable-token balance required before running ops.
BUDGET_MIN_STABLE_RAW=100000000
# Minimum volatile-token balance required before running ops.
BUDGET_MIN_VOLATILE_RAW=100000000000000000
# Stable-token amount reserved for liquidity provisioning.
BUDGET_LIQ_STABLE_RAW=300000000
# Volatile-token amount reserved for liquidity provisioning.
BUDGET_LIQ_VOLATILE_RAW=300000000000000000
# Stable-token amount reserved for swap operations.
BUDGET_SWAP_STABLE_RAW=50000000
# Volatile-token amount reserved for swap operations.
BUDGET_SWAP_VOLATILE_RAW=0
# Extra ETH buffer reserved above explicit budgets.
BUDGET_SAFETY_BUFFER_ETH_WEI=20000000000000000

# Stable-token amount used by smoke swaps.
SMOKE_SWAP_STABLE_RAW=2000000
# Stable-token amount used by full validation swaps.
FULL_SWAP_STABLE_RAW=2500000
# Number of swap iterations in the full validation flow.
FULL_SWAP_ITERATIONS=4
# Stable-token amount used by rerun-safe validation swaps.
RERUN_SWAP_STABLE_RAW=1000000
# Stable-token amount seeded into the local wallet.
SEED_STABLE_RAW=0
# Volatile-token amount seeded into the local wallet.
SEED_VOLATILE_RAW=0
# Number of periods advanced by local warp helpers.
PERIODS_TO_WARP=1
# Whether warp helpers should close the period immediately after advancing time.
WARP_CLOSE_PERIOD=true

# Enables transaction broadcasting for this profile.
OPS_BROADCAST=0

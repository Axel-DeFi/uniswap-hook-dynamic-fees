EXTREME_FEE_PIPS=9000

# Timing
PERIOD_SECONDS=60
EMA_PERIODS=8
# Literal percent, not bps. Example: 5 = 5%, 1.25 = 1.25%.
DEADBAND_PERCENT=5
LULL_RESET_SECONDS=600

# Owner / controller params
HOOK_FEE_PERCENT=10
MIN_COUNTED_SWAP_USD6=4000000
# Dollar thresholds below are literal USD amounts per close, not USD6.
# EMA thresholds are literal percent of closeVol / EMA. Example: 180 = 180% of EMA.

# Frozen constructor snapshot for canonical hook identity.
# Keep this aligned with the constructor args used for deployment.
# Runtime/admin expectations in defaults.env may drift later; these values must not.
# DEPLOY_* values must be literal and must not depend on shell expansion.

DEPLOY_POOL_MANAGER=0x0000000000000000000000000000000000000001
DEPLOY_VOLATILE=0x0000000000000000000000000000000000000002
DEPLOY_STABLE=0x0000000000000000000000000000000000000003
DEPLOY_STABLE_DECIMALS=6
DEPLOY_TICK_SPACING=10
DEPLOY_OWNER=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
DEPLOY_FLOOR_FEE_PIPS=400
DEPLOY_CASH_FEE_PIPS=2500
DEPLOY_EXTREME_FEE_PIPS=9000
DEPLOY_PERIOD_SECONDS=60
DEPLOY_EMA_PERIODS=8
# Literal percent, not bps. Example: 5 = 5%, 1.25 = 1.25%.
DEPLOY_DEADBAND_PERCENT=5
DEPLOY_LULL_RESET_SECONDS=600
DEPLOY_HOOK_FEE_PERCENT=10
# Dollar thresholds below are literal USD amounts per close, not USD6.
# EMA thresholds are literal percent of closeVol / EMA. Example: 180 = 180% of EMA.
DEPLOY_MIN_VOLUME_TO_ENTER_CASH_USD=1000
DEPLOY_CASH_ENTER_EMA_PERCENT=180
DEPLOY_CASH_HOLD_PERIODS=4
DEPLOY_MIN_VOLUME_TO_ENTER_EXTREME_USD=4000
DEPLOY_EXTREME_ENTER_EMA_PERCENT=400
DEPLOY_ENTER_EXTREME_CONFIRM_PERIODS=2
DEPLOY_EXTREME_HOLD_PERIODS=4
DEPLOY_EXTREME_EXIT_EMA_PERCENT=130
DEPLOY_EXIT_EXTREME_CONFIRM_PERIODS=2
DEPLOY_CASH_EXIT_EMA_PERCENT=130
DEPLOY_EXIT_CASH_CONFIRM_PERIODS=3
DEPLOY_EMERGENCY_FLOOR_TRIGGER_USD=600
DEPLOY_EMERGENCY_CONFIRM_PERIODS=3
